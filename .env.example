DATABASE_URL=postgresql://user:password@host:5432/database
SESSION_SECRET=replace-with-a-long-random-secret
RESEND_API_KEY=
PORT=5000
HOST=127.0.0.1
REUSE_PORT=false

# /admin is for the SEO and Content roles only — the site owner manages the site
# via GitHub + Vercel directly and does not log into this panel. Set a password
# for each role below; leave one unset to disable that role's login entirely.
SEO_PASSWORD=
CONTENT_PASSWORD=

# Leave DATABASE_URL unset to use in-memory local storage for quick UI work.

# Local-only escape hatch for this export, where attached_assets media is absent.
# Production builds should leave this unset so missing real assets fail loudly.
ALLOW_MISSING_ASSETS=false
